# Database (required)
# Local (no SSL): postgres://postgres:postgres@localhost:5432/gather_clone
# Production (e.g. Render): use your cloud URL; sslmode=require is added automatically for non-localhost
DATABASE_URL=postgres://user:password@host:5432/database_name

# JWT signing secret (required for auth)
JWT_SECRET=your_secret_change_in_production

# Allowed CORS origin for the frontend (optional, default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Optional: set to "production" to disable dev/seed endpoint
# RUST_ENV=production
